# ESP-IDF / CMake build output
build/
sdkconfig
sdkconfig.old
*.bin
*.elf
*.map

# ESP-IDF component manager. The Morse components are vendored under components/
# (git submodules), so nothing is downloaded into managed_components/. The lock
# file is regenerated on every reconfigure and, for our local components, records
# a machine-specific absolute path — so it is not committed either.
managed_components/
dependencies.lock

# Editor / OS
.vscode/
.DS_Store
*.swp

# Python
__pycache__/
*.pyc

# Note: ESP-IDF itself is NOT vendored here. It is installed out-of-tree at
# $HOME/esp/esp-idf (see firmware/README.md). Only the MM6108 SDK is vendored
# under vendor/ (as a pinned git submodule).
