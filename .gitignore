# ESP-IDF / CMake build output
build/
sdkconfig
sdkconfig.old
*.bin
*.elf
*.map

# ESP-IDF component manager. The Morse components are vendored under components/
# (git submodules), so nothing is downloaded into managed_components/. The lock
# file is regenerated on every reconfigure and, for our local components, records
# a machine-specific absolute path — so it is not committed either.
managed_components/
dependencies.lock

# Editor / OS
.vscode/
.DS_Store
*.swp

# Python
__pycache__/
*.pyc

# Note: ESP-IDF is vendored at vendor/esp-idf (pinned submodule, v5.4.2); the
# build uses it by default. The toolchain itself (compilers, Python env) is set up
# out-of-tree under ~/.espressif by vendor/esp-idf/install.sh (see firmware/README.md).
