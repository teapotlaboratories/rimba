# ESP-IDF / CMake build output
build/
sdkconfig
sdkconfig.old
*.bin
*.elf
*.map

# ESP-IDF component manager: downloaded components are regenerated from
# idf_component.yml + dependencies.lock, so they are not committed.
managed_components/

# Editor / OS
.vscode/
.DS_Store
*.swp

# Python
__pycache__/
*.pyc

# Note: ESP-IDF itself is NOT vendored here. It is installed out-of-tree at
# $HOME/esp/esp-idf (see firmware/README.md). Only the MM6108 SDK is vendored
# under vendor/ (as a pinned git submodule).
