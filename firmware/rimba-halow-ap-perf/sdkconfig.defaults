# rimba-halow-ap app config (layered on top of the board's boards/<BOARD>/ defaults).
# Put the MM6108 driver into AP (SoftAP) mode.
CONFIG_HALOW_AP_MODE=y

# High-STA AP ceiling: accept up to 255 associated stations. Valid AIDs are
# 1..255 now that the S1G TIM spans four PVB blocks (MAX_SUPPORTED_AID=256); 255
# is also the max of the public uint8_t max_stas field.
CONFIG_HALOW_AP_MAX_STAS=255
# Route per-STA umac_sta_data (~912 B each) AND the TWT agreement table to PSRAM,
# not internal SRAM — at 255 STAs that is ~230 KB that must not come from the
# small internal-SRAM pool.
CONFIG_HALOW_STA_DATA_IN_PSRAM=y


# iperf + ping console + the HaLow driver need >1.5MB; use a custom 2MB app partition (16MB flash).
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
