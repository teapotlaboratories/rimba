# bench.env.sh.example — template for your bench identity (committed; the real bench.env.sh is git-ignored).
#
# The regression suite stores NOTHING about the bench in source — you provide it. Set up your bench once:
#     cp bench.env.sh.example bench.env.sh   # then edit in YOUR values
#     source bench.env.sh                    # once per shell
#     make test-all BOARD_NAME=board2 AP=esp CYCLES=2
#
# Find a board's efuse MAC:  ls /dev/serial/by-id/   (the MAC is in the symlink name),
# or flash it and read the "Wi-Fi MAC address" line, or `esptool --port /dev/ttyACMx chip_id`.
# mesh_mac / mesh_ip / fully_wired are DERIVED from these — you never set them.
export BENCH_BOARD=proto1-fgh100m          # sdkconfig overlay under boards/<BENCH_BOARD>/
export BOARD0_MAC=xx:xx:xx:xx:xx:xx        # board0 efuse MAC (light-load / spare slot)
export BOARD1_MAC=xx:xx:xx:xx:xx:xx        # board1 efuse MAC (light-load / spare slot)
export BOARD2_MAC=xx:xx:xx:xx:xx:xx        # board2 efuse MAC (fully-wired DUT/relay/gate slot)
export WIRED_BOARD=board2                  # which board is fully wired (WAKE+BUSY); the load/relay/PS DUT
export LINUX_HOST=chronite                 # Linux interop node ssh host (only T2 interop + tp --ap linux need it)
export LINUX_MAC=xx:xx:xx:xx:xx:xx         # its wlan1 MAC
export LINUX_IP=10.9.9.2                   # its mesh IP (10.9.9.x)
