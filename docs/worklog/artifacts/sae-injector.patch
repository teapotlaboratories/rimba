+#ifdef CONFIG_TESTING_OPTIONS
+int mesh_attack_send_commit(struct wpa_supplicant *wpa_s, const u8 *addr,
+			    int mode)
+{
+	struct hostapd_data *hapd = wpa_s->ifmsh ? wpa_s->ifmsh->bss[0] : NULL;
+	struct wpa_ssid *ssid = wpa_s->current_ssid;
+	struct sta_info *sta;
+
+	if (!hapd || !ssid)
+		return -1;
+	sta = ap_get_sta(hapd, addr);
+	if (!sta || !sta->sae) {
+		wpa_printf(MSG_INFO, "SAE-ATTACK: no SAE peer " MACSTR,
+			   MAC2STR(addr));
+		return -1;
+	}
+	if (mesh_rsn_build_sae_commit(wpa_s, ssid, sta))
+		return -1;
+	sta->sae->test_corrupt_commit = mode;
+	wpa_printf(MSG_INFO, "SAE-ATTACK: sending malformed Commit mode=%d to "
+		   MACSTR, mode, MAC2STR(addr));
+	auth_sae_init_committed(hapd, sta);
+	return 0;
+}
+
+int mesh_attack_send_confirm(struct wpa_supplicant *wpa_s, const u8 *addr)
+{
+	struct hostapd_data *hapd = wpa_s->ifmsh ? wpa_s->ifmsh->bss[0] : NULL;
+	struct sta_info *sta;
+
+	if (!hapd)
+		return -1;
+	sta = ap_get_sta(hapd, addr);
+	if (!sta || !sta->sae) {
+		wpa_printf(MSG_INFO, "SAE-ATTACK: no SAE peer " MACSTR,
+			   MAC2STR(addr));
+		return -1;
+	}
+	if (!sta->sae->cached_confirm) {
+		wpa_printf(MSG_INFO,
+			   "SAE-ATTACK: no cached Confirm for " MACSTR
+			   " (peer never completed an SAE Confirm)",
+			   MAC2STR(addr));
+		return -1;
+	}
+	/* Cache-and-replay: re-send the peer's original SAE Confirm bytes
+	 * (auth txn=2) verbatim. Their send-confirm counter is stale (== the Rc
+	 * the peer already accepted), so the peer's anti-replay defense must
+	 * drop it. We do NOT rebuild via sae_write_confirm(): post-ESTAB
+	 * sae_accept_sta() has NULLed peer_commit_scalar and that path would
+	 * crash. */
+	return auth_sae_send_confirm_replay(hapd, sta);
+}
+#endif /* CONFIG_TESTING_OPTIONS */
