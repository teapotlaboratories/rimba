+#ifdef CONFIG_TESTING_OPTIONS
+/* GAP-#15 unsolicited-open: when set, mesh_mpm_send_plink_action() forces
+ * ampe=0 so a peering Open is emitted with no AMPE IE / no PMKID -- and thus
+ * needs no prior SAE/PMKSA with the target. Set/cleared synchronously around
